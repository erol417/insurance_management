@model InsuranceManagement.Web.Domain.Employee
@{
    var openLeadsCount = (int)(ViewBag.OpenLeadsCount ?? 0);
    var activitiesCount = (int)(ViewBag.ActivitiesCount ?? 0);
    var salesCount = (int)(ViewBag.SalesCount ?? 0);
    var expensesSum = (decimal)(ViewBag.ExpensesSum ?? 0m);
    
    var plannedActivities = ViewBag.PlannedActivities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
    var relatedLeads = ViewBag.RelatedLeads as List<InsuranceManagement.Web.Domain.Lead> ?? [];
    var relatedSales = ViewBag.RelatedSales as List<InsuranceManagement.Web.Domain.Sale> ?? [];
    var relatedExpenses = ViewBag.RelatedExpenses as List<InsuranceManagement.Web.Domain.Expense> ?? [];
    
    ViewData["Title"] = "";
    ViewData["Subtitle"] = "";
}

<div class="page-header" style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 32px; border-bottom: 1px solid var(--line); padding-bottom: 24px;">
    <div>
        <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap;">
            <h1 style="margin: 0; font-size: 32px; font-weight: 800; color: var(--text);">@Model.FullName</h1>
            <div style="display: flex; gap: 8px;">
                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn primary-outline" style="padding: 6px 12px; border-radius: 8px; display: flex; align-items: center; gap: 6px;" title="Personeli Düzenle">
                        <i data-lucide="edit-3" style="width: 16px; height: 16px;"></i> <span class="hide-mobile">Düzenle</span>
                    </a>
                }
                <a asp-controller="LeadAssignments" asp-action="Index" asp-route-employeeId="@Model.Id" class="btn primary" style="padding: 6px 12px; border-radius: 8px; display: flex; align-items: center; gap: 6px;" title="Yeni İş Ata">
                    <i data-lucide="user-plus" style="width: 16px; height: 16px;"></i> <span class="hide-mobile">İş Ata</span>
                </a>
            </div>
        </div>
        <div style="margin-top: 10px; display: flex; align-items: center; gap: 12px; color: var(--muted); font-size: 14px; flex-wrap: wrap;">
            <span style="display: flex; align-items: center; gap: 4px;">
                <i data-lucide="map-pin" style="width: 14px;"></i> @Model.Region / @Model.City
            </span>
            <span class="v-divider" style="width: 4px; height: 4px; border-radius: 50%; background: var(--line);"></span>
            <span style="display: flex; align-items: center; gap: 4px; color: var(--success); font-weight: 600;">
                <i data-lucide="check-circle-2" style="width: 14px;"></i> Aktif Çalışan
            </span>
        </div>
    </div>
</div>

<div class="form-layout">
    <div class="layout-main" style="width: 100%;">

        <!-- Metric Overview -->
        <section class="section-block">
            <div class="panel-title">
                <h3>Performans Özeti</h3>
                <span class="pill">@Model.Region</span>
            </div>
            <div class="metric-grid four">
                <article class="metric-card">
                    <span class="metric-label">Açık Lead</span>
                    <strong>@openLeadsCount</strong>
                    <small>Yüklenen/Atanan</small>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Aktivite</span>
                    <strong>@activitiesCount</strong>
                    <small>Tamamlanan</small>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Satış</span>
                    <strong>@salesCount</strong>
                    <small>Üretim Adedi</small>
                </article>
                <article class="metric-card">
                    <span class="metric-label">Masraf</span>
                    <strong>@expensesSum.ToString("N2") ₺</strong>
                    <small>Toplam Talepler</small>
                </article>
            </div>
        </section>

        <!-- Ziyaret Takvimi -->
        @{
            bool showCalendarDefault = Context.Request.Query.ContainsKey("weekStart");
        }
        <section class="section-block" style="border-left: 4px solid var(--primary);">
            <div class="panel-title" style="display:flex; justify-content:space-between; align-items:center; cursor:pointer;" onclick="toggleCalendar()">
                <div style="display:flex; align-items:center; gap:12px;">
                    <h3>Haftalık Ziyaret Takvimi</h3>
                    <div class="pill highlight">Planlama</div>
                    <i id="calendar-icon" data-lucide="@(showCalendarDefault ? "chevron-up" : "chevron-down")" style="width:18px; color:var(--muted);"></i>
                </div>
            </div>
            
            <div id="calendar-container" style="display:@(showCalendarDefault ? "block" : "none");">
                @{
                    var ws = (DateTime)ViewBag.WeekStart;
                    var prevWs = ws.AddDays(-7).ToString("yyyy-MM-dd");
                    var nextWs = ws.AddDays(7).ToString("yyyy-MM-dd");
                    var todayWs = DateTime.Today.AddDays(-(int)DateTime.Today.DayOfWeek + (int)DayOfWeek.Monday).ToString("yyyy-MM-dd");
                    var weeklyActs = ViewBag.WeeklyCalendar as List<InsuranceManagement.Web.Domain.Activity> ?? new();
                }
                
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px;">
                    <div style="color:var(--muted); font-size:13px; font-weight:600;">
                        @ws.ToString("dd.MM.yyyy") - @ws.AddDays(4).ToString("dd.MM.yyyy")
                    </div>
                    <div style="display:flex; gap:8px;">
                        <a asp-action="Details" asp-route-id="@Model.Id" asp-route-weekStart="@prevWs" class="btn primary-outline" style="padding: 4px 12px; font-size:12px;" onclick="event.stopPropagation();">&lt; Önceki Hafta</a>
                        <a asp-action="Details" asp-route-id="@Model.Id" asp-route-weekStart="@todayWs" class="btn ghost" style="padding: 4px 12px; font-size:12px;" onclick="event.stopPropagation();">Bu Hafta</a>
                        <a asp-action="Details" asp-route-id="@Model.Id" asp-route-weekStart="@nextWs" class="btn primary-outline" style="padding: 4px 12px; font-size:12px;" onclick="event.stopPropagation();">Sonraki Hafta &gt;</a>
                    </div>
                </div>
                <div class="table-scroll">
                    <table class="data-table" style="table-layout: fixed; min-width: 800px;">
                        <thead>
                            <tr>
                                <th style="width: 60px; text-align:center;">Saat</th>
                                <th>Pazartesi</th>
                                <th>Salı</th>
                                <th>Çarşamba</th>
                                <th>Perşembe</th>
                                <th>Cuma</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (int h = 8; h <= 18; h++)
                            {
                                <tr>
                                    <td style="text-align:center; font-weight:600; color:var(--muted); font-size:12px; background:#f8fafc; border-right: 1px solid var(--line);">@h.ToString("00"):00</td>
                                    @for (int d = 0; d < 5; d++)
                                    {
                                        var dayDate = ws.AddDays(d).Date;
                                        var cellActs = weeklyActs.Where(a => a.PlannedAt.HasValue && a.PlannedAt.Value.Date == dayDate && a.PlannedAt.Value.Hour == h).ToList();
                                        
                                        <td style="vertical-align:top; padding:4px; height: 60px; border-right: 1px dashed var(--line);">
                                            @foreach (var act in cellActs)
                                            {
                                                var targetClass = act.LeadId.HasValue ? "success" : "primary";
                                                var targetName = act.Lead != null ? act.Lead.DisplayName : (act.Account != null ? act.Account.DisplayName : "Bilinmiyor");
                                                <div style="background:var(--@(targetClass)-light, #ecfdf5); border-left: 3px solid var(--@targetClass); padding: 4px 8px; border-radius:4px; margin-bottom:4px; font-size:11px; cursor:pointer;" title="@act.Summary">
                                                    <div style="font-weight:700; color:var(--text); margin-bottom:2px;">@act.PlannedAt?.ToString("HH:mm")</div>
                                                    <div style="color:var(--text-muted); white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@targetName</div>
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Related Leads -->
        <section class="section-block">
            <div class="panel-title">
                <h3>Üzerindeki İşler (Leadler)</h3>
                <a asp-controller="Leads" asp-action="Index" asp-route-employeeId="@Model.Id" class="btn link-btn">Tümünü Gör</a>
            </div>
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Kod</th>
                            <th>Müşteri / Ünvan</th>
                            <th>Öncelik</th>
                            <th>Durum</th>
                            <th style="text-align:right;">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in relatedLeads)
                        {
                            <tr>
                                <td><code>@lead.Code</code></td>
                                <td>@lead.DisplayName</td>
                                <td><span class="priority-pill @lead.Priority.ToString().ToLower()">@lead.Priority</span></td>
                                <td>@lead.LeadStatusType.Name</td>
                                <td style="text-align:right;">
                                    <a asp-controller="Leads" asp-action="Hub" asp-route-id="@lead.Id" class="btn primary-outline" style="font-size:11px; padding:4px 8px;">Detay</a>
                                </td>
                            </tr>
                        }
                        @if (!relatedLeads.Any())
                        {
                            <tr><td colspan="5" class="muted" style="text-align:center; padding:20px;">Atanmış aktif iş bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Production / Sales -->
        <section class="section-block">
            <div class="panel-title">
                <h3>Üretim Detayı (Satışlar)</h3>
                <a asp-controller="Sales" asp-action="Index" class="btn link-btn">Satışlara Git</a>
            </div>
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Kod</th>
                            <th>Ürün Tipi</th>
                            <th>Tutar (APE)</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sale in relatedSales)
                        {
                            <tr>
                                <td><code>@sale.Code</code></td>
                                <td>@sale.InsuranceProductType?.Name</td>
                                <td><strong>@sale.ApeAmount?.ToString("N2") ₺</strong></td>
                                <td>@sale.CreatedAt.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                        @if (!relatedSales.Any())
                        {
                            <tr><td colspan="4" class="muted" style="text-align:center; padding:20px;">Henüz satış kaydı bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Expenses -->
        <section class="section-block">
            <div class="panel-title">
                <h3>Masraf Talepleri</h3>
                <a asp-controller="Expenses" asp-action="Index" class="btn link-btn">Masraflara Git</a>
            </div>
            <div class="table-scroll">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Kod</th>
                            <th>Tip</th>
                            <th>Tutar</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var exp in relatedExpenses)
                        {
                            <tr>
                                <td><code>@exp.Code</code></td>
                                <td>@exp.ExpenseTypeEntity?.Name</td>
                                <td style="color:var(--danger)">@exp.Amount.ToString("N2") ₺</td>
                                <td>@exp.ExpenseDate.ToString("dd.MM.yyyy")</td>
                            </tr>
                        }
                        @if (!relatedExpenses.Any())
                        {
                            <tr><td colspan="4" class="muted" style="text-align:center; padding:20px;">Henüz masraf kaydı bulunmuyor.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>

<script>
    function toggleCalendar() {
        var container = document.getElementById('calendar-container');
        var icon = document.getElementById('calendar-icon');
        if (container.style.display === 'none') {
            container.style.display = 'block';
            icon.setAttribute('data-lucide', 'chevron-up');
        } else {
            container.style.display = 'none';
            icon.setAttribute('data-lucide', 'chevron-down');
        }
        if (window.lucide) window.lucide.createIcons();
    }
</script>
