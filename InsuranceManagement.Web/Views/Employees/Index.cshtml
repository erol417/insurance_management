@model List<InsuranceManagement.Web.Domain.Employee>
@{
    ViewData["Title"] = "Personeller";
    ViewData["Subtitle"] = "Saha ve operasyon personel kayitlari";
}
<div class="page-actions">
    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
    {
        <a class="btn primary" asp-action="Create">Yeni Personel</a>
    }
</div>
<div class="panel" style="margin-top:18px;">
    <table class="table">
        <thead><tr><th>Ad</th><th>Bolge</th><th>Sehir</th></tr></thead>
        <tbody>
        @foreach (var employee in Model)
        {
            <tr><td><a asp-action="Details" asp-route-id="@employee.Id">@employee.FullName</a></td><td>@employee.Region</td><td>@employee.City</td></tr>
        }
        </tbody>
    </table>
</div>
