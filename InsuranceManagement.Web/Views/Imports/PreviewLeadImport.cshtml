@model InsuranceManagement.Web.ViewModels.LeadImportPreviewViewModel
@{
    ViewData["Title"] = "Lead Import Onizleme";
    ViewData["Subtitle"] = "CSV satirlari kontrol edilip toplu iceri alma oncesi onizlenir";
}
<div class="page-actions">
    <a class="btn" asp-action="Upload">Yeni Dosya Yukle</a>
    <a class="btn secondary" asp-action="History">Import Gecmisi</a>
    @if (Model.ValidRows > 0)
    {
        <form method="post" asp-action="CommitLeadImport" asp-route-id="@Model.BatchId" class="inline-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn primary">@Model.ValidRows Satiri Ice Al</button>
        </form>
    }
</div>
<div class="grid cards-3" style="margin-top:18px;">
    <div class="panel metric">
        <span class="tag">Toplam Satir</span>
        <div class="value">@Model.TotalRows</div>
    </div>
    <div class="panel metric">
        <span class="tag">Gecerli Satir</span>
        <div class="value">@Model.ValidRows</div>
    </div>
    <div class="panel metric">
        <span class="tag">Hatali Satir</span>
        <div class="value">@Model.InvalidRows</div>
    </div>
</div>
<div class="panel" style="margin-top:18px;">
    <div class="note-box">
        <strong>Dosya</strong>
        <p>@Model.FileName</p>
        <p>Hata iceren satirlar ice alinmaz. Uyari iceren ama hatasiz satirlar ice alinabilir.</p>
    </div>
    <div class="table-scroll">
        <table class="table compact-table">
            <thead>
                <tr>
                    <th>Satir</th>
                    <th>Ad / Unvan</th>
                    <th>Sehir</th>
                    <th>Telefon</th>
                    <th>E-posta</th>
                    <th>Durum</th>
                    <th>Atanan</th>
                    <th>Kontrol</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.RowNumber</td>
                    <td>
                        <strong>@row.DisplayName</strong>
                        <div class="muted">@row.ContactName</div>
                    </td>
                    <td>@row.City</td>
                    <td>@row.Phone</td>
                    <td>@row.Email</td>
                    <td>@row.StatusText</td>
                    <td>@(string.IsNullOrWhiteSpace(row.AssignedEmployee) ? "-" : row.AssignedEmployee)</td>
                    <td>
                        @if (row.CanImport)
                        {
                            <span class="status ok">Ice Alinabilir</span>
                        }
                        else
                        {
                            <span class="status bad">Hata Var</span>
                        }
                        @foreach (var error in row.Errors)
                        {
                            <p class="import-error">@error</p>
                        }
                        @foreach (var warning in row.Warnings)
                        {
                            <p class="import-warning">@warning</p>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>
