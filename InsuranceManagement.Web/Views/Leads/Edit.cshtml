@model InsuranceManagement.Web.ViewModels.LeadFormViewModel
@{
    var duplicateWarnings = ViewBag.DuplicateWarnings as IEnumerable<string> ?? [];
    ViewData["Title"] = "Lead Duzenle";
    ViewData["Subtitle"] = "Lead bilgisini guncelle";
}
<div class="panel">
    <form method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="validation-summary-errors"></div>
        @if (duplicateWarnings.Any())
        {
            <div class="note-box warning">
                <strong>Benzer kayit uyarilari</strong>
                @foreach (var warning in duplicateWarnings)
                {
                    <p>@warning</p>
                }
            </div>
        }
        <div class="form-grid three">
            <div class="field"><label asp-for="DisplayName"></label><input asp-for="DisplayName" /></div>
            <div class="field"><label asp-for="City"></label><input asp-for="City" /></div>
            <div class="field"><label asp-for="District"></label><input asp-for="District" /></div>
            <div class="field"><label asp-for="ContactName"></label><input asp-for="ContactName" /></div>
            <div class="field"><label asp-for="Phone"></label><input asp-for="Phone" /></div>
            <div class="field"><label asp-for="Email"></label><input asp-for="Email" /></div>
            <div class="field"><label asp-for="Source"></label><input asp-for="Source" /></div>
            <div class="field">
                <label asp-for="Status"></label>
                <select asp-for="Status">
                    <option value="New">Yeni</option><option value="Researched">Arastirildi</option><option value="ContactFound">Kontak Bulundu</option><option value="ReadyForAssignment">Atamaya Hazir</option><option value="Assigned">Atandi</option><option value="VisitScheduled">Ziyaret Planlandi</option><option value="Visited">Ziyaret Edildi</option><option value="ConvertedToActivity">Aktiviteye Donustu</option><option value="Disqualified">Elenmis</option>
                </select>
            </div>
            <div class="field"><label asp-for="Priority"></label><input asp-for="Priority" /></div>
        </div>
        <div class="field"><label asp-for="Note"></label><textarea asp-for="Note"></textarea></div>
        <div class="page-actions"><button type="submit" class="btn primary">Guncelle</button></div>
    </form>
</div>
