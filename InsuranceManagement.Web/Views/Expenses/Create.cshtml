@model InsuranceManagement.Web.ViewModels.ExpenseFormViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    ViewData["Title"] = "Yeni Masraf";
    ViewData["Subtitle"] = "Yol, yemek, konaklama ve diger masraflar";
}

<div class="form-layout">
    <div class="layout-main">
        <section class="section-block">
            <h3>Masraf Bilgileri</h3>
            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>
                <div class="form-grid three">
                    <div class="field"><label asp-for="ExpenseDate"></label><input asp-for="ExpenseDate" type="date" /></div>
                    <div class="field"><label asp-for="EmployeeId"></label><select asp-for="EmployeeId">@foreach (var employee in employees){<option value="@employee.Id">@employee.FullName</option>}</select></div>
                    <div class="field">
                        <label>Masraf Turu</label>
                        <select asp-for="ExpenseTypeId">
                            @foreach (var type in (List<InsuranceManagement.Web.Domain.ExpenseReferenceType>)ViewBag.ExpenseTypes)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field"><label asp-for="Amount"></label><input asp-for="Amount" /></div>
                </div>
                <div class="field"><label asp-for="Notes"></label><textarea asp-for="Notes"></textarea></div>
                <div class="page-actions"><button type="submit" class="btn primary">Masrafi Kaydet</button></div>
            </form>
        </section>
    </div>
    <aside class="side-stack">
        <section class="side-panel soft">
            <h3>Baglamsal Aksiyonlar ve Rehber</h3>
        </section>
        <section class="side-panel">
            <h4 style="margin-bottom:14px;">Hizli Aksiyonlar</h4>
            <div class="action-buttons">
                <button class="btn primary" type="button">Masraf Politikasi</button>
                <button class="btn primary" type="button">Personel Karti</button>
            </div>
        </section>
        <section class="side-panel soft">
            <h4 style="margin-bottom:16px;">Kayit Rehberi</h4>
            <div class="timeline">
                <div class="timeline-item">
                    <strong>Masraf tipi</strong>
                    <div>Dogru tip secimi dashboard masraf analizlerindeki kategori dagilimini etkiler.</div>
                </div>
                <div class="timeline-item">
                    <strong>Personel baglantisi</strong>
                    <div>Masraf mutlaka ilgili personel ile eslenmeli; aksi halde performans ve verimlilik raporlari bozulur.</div>
                </div>
                <div class="timeline-item">
                    <strong>Sonraki adim</strong>
                    <div>Kayit sonrasi aylik masraf trendinde otomatik gorunur ve yonetici ozetlerine yansir.</div>
                </div>
            </div>
        </section>
    </aside>
</div>
