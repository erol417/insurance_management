@model InsuranceManagement.Web.ViewModels.ActivityFormViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var accounts = ViewBag.Accounts as List<InsuranceManagement.Web.Domain.Account> ?? [];
    var leads = ViewBag.Leads as List<InsuranceManagement.Web.Domain.Lead> ?? [];
    ViewData["Title"] = "Yeni Aktivite";
    ViewData["Subtitle"] = "Once gorusuldu mu, sonra gerekiyorsa sonuc secilir";
}

<div class="form-layout">
    <div class="layout-main">
        <section class="section-block">
            <h3>Aktivite Bilgileri</h3>
            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>
                <div class="form-grid three">
                    <div class="field"><label asp-for="ActivityDate"></label><input asp-for="ActivityDate" type="date" /></div>
                    <div class="field"><label asp-for="EmployeeId"></label><select asp-for="EmployeeId">@foreach (var employee in employees){<option value="@employee.Id">@employee.FullName</option>}</select></div>
                    <div class="field"><label asp-for="AccountId"></label><select asp-for="AccountId">@foreach (var account in accounts){<option value="@account.Id">@account.DisplayName</option>}</select></div>
                    <div class="field"><label asp-for="LeadId"></label><select asp-for="LeadId"><option value="">Lead yok</option>@foreach (var lead in leads){<option value="@lead.Id">@lead.Code - @lead.DisplayName</option>}</select></div>
                    <div class="field"><label asp-for="ContactName"></label><input asp-for="ContactName" /></div>
                    <div class="field">
                        <label>Gorusme Durumu</label>
                        <select asp-for="ContactStatusTypeId" data-contact-status>
                            @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityContactStatusType>)ViewBag.ContactStatusTypes)
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field" data-outcome-wrapper>
                        <label>Gorusme Sonucu</label>
                        <select asp-for="OutcomeStatusTypeId">
                            <option value="">Seciniz...</option>
                            @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityOutcomeStatusType>)ViewBag.OutcomeStatusTypes)
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="field"><label asp-for="Summary"></label><textarea asp-for="Summary"></textarea></div>
                <div class="page-actions"><button type="submit" class="btn primary">Aktiviteyi Kaydet</button></div>
            </form>
        </section>
    </div>
    <aside class="side-stack">
        <section class="side-panel soft">
            <h3>Baglamsal Aksiyonlar ve Rehber</h3>
        </section>
        <section class="side-panel">
            <h4 style="margin-bottom:14px;">Hizli Aksiyonlar</h4>
            <div class="action-buttons">
                <button class="btn primary" type="button">Takvim Hatirlatici</button>
                <button class="btn primary" type="button">Lead Detayi</button>
            </div>
        </section>
        <section class="side-panel soft">
            <h4 style="margin-bottom:16px;">Kayit Rehberi</h4>
            <div class="timeline">
                <div class="timeline-item">
                    <strong>Gorusme durumu</strong>
                    <div>`Gorusulmedi` secilirse sonuc alani otomatik kapanir ve anlamsiz kombinasyonlar engellenir.</div>
                </div>
                <div class="timeline-item">
                    <strong>Lead baglantisi</strong>
                    <div>Aktiviteyi lead ile baglamak donusum zincirini raporlarda daha dogru gosterir.</div>
                </div>
                <div class="timeline-item">
                    <strong>Sonraki adim</strong>
                    <div>Kayit sonrasi satis veya ikinci ziyaret aksiyonu acilabilir.</div>
                </div>
            </div>
        </section>
    </aside>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const contactSelect = document.querySelector('[data-contact-status]');
            const outcomeWrapper = document.querySelector('[data-outcome-wrapper]');
            const outcomeSelect = document.querySelector('#OutcomeStatusTypeId');

            function sync() {
                const contacted = contactSelect.value === "1"; // "1" is CONTACTED
                if (contacted) {
                    outcomeWrapper.style.display = 'block';
                } else {
                    outcomeWrapper.style.display = 'none';
                    outcomeSelect.value = "";
                }
            }

            contactSelect.addEventListener('change', sync);
            sync();
        });
    </script>
}
