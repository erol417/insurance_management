@model InsuranceManagement.Web.ViewModels.ActivitiesIndexViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var accounts = ViewBag.Accounts as List<InsuranceManagement.Web.Domain.Account> ?? [];
    var leads = ViewBag.Leads as List<InsuranceManagement.Web.Domain.Lead> ?? [];
    var canManageAll = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("SalesManager") || User.IsInRole("Operations");
    var prevPage = Math.Max(1, Model.CurrentPage - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
    ViewData["Title"] = "Aktiviteler";
    ViewData["Subtitle"] = "Saha ziyaret ve gorusme kayitlari";
}

<div class="premium-strip">
    <div>
        <strong>Aktivite Yonetim Merkezi</strong>
        <span>Ziyaret, gorusme ve sonuc kayitlarini tek tablo uzerinden takip et.</span>
    </div>
    <div class="inline-actions">
        <a class="btn primary" asp-action="Create">Yeni Aktivite</a>
    </div>
</div>

<div class="panel filters-bar">
    <form method="get" class="filters-inline">
        <div class="filter-group">
            <i data-lucide="search"></i>
            <input type="text" name="searchTerm" placeholder="Ozet veya Musteri..." value="@ViewBag.SearchTerm" />
        </div>
        
        @if (canManageAll)
        {
            <select name="employeeId" class="filter-select">
                <option value="">-- Personel --</option>
                @foreach (var emp in employees)
                {
                    <option value="@emp.Id" selected="@(ViewBag.EmployeeId == emp.Id)">@emp.FullName</option>
                }
            </select>
        }

        <div class="filter-actions">
            <button type="submit" class="btn primary btn-icon-only" title="Filtrele">
                <i data-lucide="filter"></i>
            </button>
            <a asp-action="Index" class="btn ghost btn-icon-only" title="Temizle">
                <i data-lucide="rotate-ccw"></i>
            </a>
        </div>
    </form>
</div>

<div class="page-actions" style="margin-bottom:14px;">
    <button type="button" class="btn" onclick="toggleActivityInsertRow()">Yeni Satir Ekle</button>
    <button type="button" class="btn secondary" id="save-all-activities-btn">Degisiklikleri Kaydet</button>
    <button type="button" class="btn ghost" id="clear-activity-draft-btn">Taslagi Temizle</button>
</div>

@{
    var plannedActivities = ViewBag.PlannedActivities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
}

@if (plannedActivities.Any())
{
    <div class="panel" style="border-left: 4px solid var(--primary); margin-bottom: 24px;">
        <div class="panel-title">
            <h3>Yaklaşan Randevular / Planlanan İşler</h3>
            <span class="pill highlight">@plannedActivities.Count Ajanda Kaydı</span>
        </div>
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Tarih</th>
                        <th>Personel</th>
                        <th>Müşteri</th>
                        <th>İlgili Lead</th>
                        <th style="text-align:right;">İşlem</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var act in plannedActivities)
                    {
                        <tr style="background: #f0f7ff;">
                            <td><strong>@act.ActivityDate.ToString("dd.MM.yyyy")</strong></td>
                            <td>@act.Employee?.FullName</td>
                            <td>@act.Account?.DisplayName</td>
                            <td>@(act.Lead?.Code ?? "-")</td>
                            <td style="text-align:right;">
                                <a asp-action="Edit" asp-route-id="@act.Id" class="btn primary">Gerçekleştir</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="panel">
    <div class="note-box">
        <strong>Grid duzenleme</strong>
        <p>Bu ekranda aktiviteler tablo uzerinden hizli duzenlenir. Tum degisiklikler taslakta tutulur ve tek kaydetme ile veritabanina yazilir.</p>
        <p>Sayfalar arasinda gezsen bile taslak korunur. Kaydetmeden sayfadan ayrilirsan sistem seni uyarir.</p>
    </div>
    <div class="table-scroll">
        <table class="data-table compact-table">
            <thead>
                <tr>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "code" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="code" 
                           asp-route-isDescending="@(ViewBag.SortBy == "code" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Kod @if(ViewBag.SortBy == "code") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "date" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="date" 
                           asp-route-isDescending="@(ViewBag.SortBy == "date" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Tarih @if(ViewBag.SortBy == "date") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "employee" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="employee" 
                           asp-route-isDescending="@(ViewBag.SortBy == "employee" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Personel @if(ViewBag.SortBy == "employee") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "customer" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="customer" 
                           asp-route-isDescending="@(ViewBag.SortBy == "customer" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Musteri @if(ViewBag.SortBy == "customer") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Lead</th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "contact" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="contact" 
                           asp-route-isDescending="@(ViewBag.SortBy == "contact" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Kontak @if(ViewBag.SortBy == "contact") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "status" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="status" 
                           asp-route-isDescending="@(ViewBag.SortBy == "status" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Gorusme @if(ViewBag.SortBy == "status") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "outcome" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="outcome" 
                           asp-route-isDescending="@(ViewBag.SortBy == "outcome" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Sonuc @if(ViewBag.SortBy == "outcome") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Ozet</th>
                </tr>
            </thead>
            <tbody>
                <tr id="activity-insert-row" class="inline-entry-row" style="display:none;">
                    <td><span class="muted">Yeni</span></td>
                    <td><input data-field="activityDate" type="date" class="cell-input" value="@Model.NewActivity.ActivityDate.ToString("yyyy-MM-dd")" /></td>
                    <td>
                        @if (canManageAll)
                        {
                            <select data-field="employeeId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var employee in employees)
                                {
                                    <option value="@employee.Id">@employee.FullName</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="hidden" data-field="employeeId" value="@Model.NewActivity.EmployeeId" />
                            <span class="pill">@employees.FirstOrDefault()?.FullName</span>
                        }
                    </td>
                    <td>
                        <select data-field="accountId" class="cell-input cell-select">
                            <option value="">Sec</option>
                            @foreach (var account in accounts)
                            {
                                <option value="@account.Id">@account.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="leadId" class="cell-input cell-select">
                            <option value="">-</option>
                            @foreach (var lead in leads)
                            {
                                <option value="@lead.Id">@lead.Code - @lead.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td><input data-field="contactName" class="cell-input" placeholder="Kontak" /></td>
                    <td>
                        <select data-field="contactStatusTypeId" class="cell-input cell-select js-contact-status">
                            @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityContactStatusType>)ViewBag.ContactStatusTypes)
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="outcomeStatusTypeId" class="cell-input cell-select js-outcome-status">
                            <option value="">-</option>
                            @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityOutcomeStatusType>)ViewBag.OutcomeStatusTypes)
                            {
                                <option value="@status.Id">@status.Name</option>
                            }
                        </select>
                    </td>
                    <td><input data-field="summary" class="cell-input" placeholder="Ozet" /></td>
                </tr>
                @foreach (var activity in Model.Items)
                {
                    <tr data-activity-id="@activity.Id">
                        <td><a asp-action="Details" asp-route-id="@activity.Id">@activity.Code</a></td>
                        <td><input data-field="activityDate" type="date" class="cell-input" value="@activity.ActivityDate.ToString("yyyy-MM-dd")" /></td>
                        <td>
                            @if (canManageAll)
                            {
                                <select data-field="employeeId" class="cell-input cell-select">
                                    <option value="">Sec</option>
                                    @foreach (var employee in employees)
                                    {
                                        @if (activity.EmployeeId == employee.Id)
                                        {
                                            <option value="@employee.Id" selected>@employee.FullName</option>
                                        }
                                        else
                                        {
                                            <option value="@employee.Id">@employee.FullName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" data-field="employeeId" value="@activity.EmployeeId" />
                                <span class="pill">@employees.FirstOrDefault(x => x.Id == activity.EmployeeId)?.FullName</span>
                            }
                        </td>
                        <td>
                            <select data-field="accountId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var account in accounts)
                                {
                                    @if (activity.AccountId == account.Id)
                                    {
                                        <option value="@account.Id" selected>@account.DisplayName</option>
                                    }
                                    else
                                    {
                                        <option value="@account.Id">@account.DisplayName</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="leadId" class="cell-input cell-select">
                                <option value="">-</option>
                                @foreach (var lead in leads)
                                {
                                    @if (activity.LeadId == lead.Id)
                                    {
                                        <option value="@lead.Id" selected>@lead.Code - @lead.DisplayName</option>
                                    }
                                    else
                                    {
                                        <option value="@lead.Id">@lead.Code - @lead.DisplayName</option>
                                    }
                                }
                            </select>
                        </td>
                        <td><input data-field="contactName" class="cell-input" value="@activity.ContactName" /></td>
                        <td>
                            <select data-field="contactStatusTypeId" class="cell-input cell-select js-contact-status">
                                @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityContactStatusType>)ViewBag.ContactStatusTypes)
                                {
                                    <option value="@status.Id" selected="@(activity.ContactStatusTypeId == status.Id)">@status.Name</option>
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="outcomeStatusTypeId" class="cell-input cell-select js-outcome-status">
                                <option value="">-</option>
                                @foreach (var status in (List<InsuranceManagement.Web.Domain.ActivityOutcomeStatusType>)ViewBag.OutcomeStatusTypes)
                                {
                                    <option value="@status.Id" selected="@(activity.OutcomeStatusTypeId == status.Id)">@status.Name</option>
                                }
                            </select>
                        </td>
                        <td><input data-field="summary" class="cell-input" value="@activity.Summary" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="page-actions split-actions" style="margin-top:16px;">
        <div class="pager">
            <a class="btn ghost grid-page-link @(Model.CurrentPage == 1 ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@prevPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-employeeId="@ViewBag.EmployeeId"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Onceki</a>
            
            <span class="pill">Sayfa @Model.CurrentPage / @Model.TotalPages</span>
            
            <a class="btn ghost grid-page-link @(Model.CurrentPage == Model.TotalPages ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@nextPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-employeeId="@ViewBag.EmployeeId"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Sonraki</a>
        </div>
        <div class="muted">Toplam @Model.TotalCount kayit</div>
    </div>
</div>

@await Html.PartialAsync("_GridBulkSaveForm", new InsuranceManagement.Web.ViewModels.GridBulkSaveFormViewModel
{
    ActionName = "BulkSave",
    FormId = "activity-bulk-save-form",
    PayloadInputId = "activity-bulk-payload",
    Page = Model.CurrentPage
})

@section Scripts {
    <script>
        function toggleActivityInsertRow() {
            InsuranceGridDraft.toggleRow("activity-insert-row");
        }

        function syncOutcomeState(row) {
            const contact = row.querySelector(".js-contact-status");
            const outcome = row.querySelector(".js-outcome-status");
            if (!contact || !outcome) return;
            const contacted = contact.value === "1";
            outcome.disabled = !contacted;
            if (!contacted) {
                outcome.value = "";
            }
        }

        InsuranceGridDraft.create({
            storageKey: "activity-grid-draft-v1",
            rowSelector: "tr[data-activity-id]",
            rowIdAttribute: "data-activity-id",
            insertRowId: "activity-insert-row",
            saveButtonId: "save-all-activities-btn",
            clearButtonId: "clear-activity-draft-btn",
            formId: "activity-bulk-save-form",
            payloadInputId: "activity-bulk-payload",
            clearOnLoad: @(((TempData["ClearGridDraftKey"] as string) == "activity-grid-draft-v1").ToString().ToLowerInvariant()),
            onRowReady: syncOutcomeState,
            onInsertRowReady: syncOutcomeState,
            afterDraftApplied: syncOutcomeState
        });
    </script>
}
