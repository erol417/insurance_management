@model InsuranceManagement.Web.ViewModels.SalesIndexViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var accounts = ViewBag.Accounts as List<InsuranceManagement.Web.Domain.Account> ?? [];
    var activities = ViewBag.Activities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
    var canManageAll = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("SalesManager") || User.IsInRole("Operations");
    var prevPage = Math.Max(1, Model.CurrentPage - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
    ViewData["Title"] = "Satislar";
    ViewData["Subtitle"] = "Aktiviteye bagli veya bagimsiz satis kayitlari";
}

<div class="premium-strip">
    <div>
        <strong>Satis Yonetim Merkezi</strong>
        <span>Uretim, tahsilat ve urun bazli satis kayitlarini tek tablo uzerinden yonet.</span>
    </div>
    <div class="inline-actions">
        <a class="btn primary" asp-action="Create">Detayli Form</a>
    </div>
</div>

<div class="panel filters-bar">
    <form method="get" class="filters-inline">
        <div class="filter-group">
            <i data-lucide="search"></i>
            <input type="text" name="searchTerm" placeholder="Musteri veya Kod..." value="@ViewBag.SearchTerm" />
        </div>
        
        @if (canManageAll)
        {
            <select name="employeeId" class="filter-select">
                <option value="">-- Personel --</option>
                @foreach (var emp in employees)
                {
                    <option value="@emp.Id" selected="@(ViewBag.EmployeeId == emp.Id)">@emp.FullName</option>
                }
            </select>
        }

        <div class="filter-actions">
            <button type="submit" class="btn primary btn-icon-only" title="Filtrele">
                <i data-lucide="filter"></i>
            </button>
            <a asp-action="Index" class="btn ghost btn-icon-only" title="Temizle">
                <i data-lucide="rotate-ccw"></i>
            </a>
        </div>
    </form>
</div>

<div class="page-actions" style="margin-bottom:14px;">
    <button type="button" class="btn" onclick="toggleSaleInsertRow()">Yeni Satir Ekle</button>
    <button type="button" class="btn secondary" id="save-all-sales-btn">Degisiklikleri Kaydet</button>
    <button type="button" class="btn ghost" id="clear-sale-draft-btn">Taslagi Temizle</button>
</div>

<div class="panel">
    <div class="note-box">
        <strong>Grid duzenleme</strong>
        <p>Satis kayitlari tablo uzerinden hizli giris icin duzenlenebilir. Degisiklikler taslakta tutulur ve tek kaydetme ile islenir.</p>
        <p>Urun tipine gore finansal alanlar ayni satirda gorunur; bu da ozellikle aylik tahsilat ve BES kirilimlarinda hizi artirir.</p>
    </div>
    <div class="table-scroll">
        <table class="data-table compact-table">
            <thead>
                <tr>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "code" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="code" 
                           asp-route-isDescending="@(ViewBag.SortBy == "code" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Kod @if(ViewBag.SortBy == "code") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "date" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="date" 
                           asp-route-isDescending="@(ViewBag.SortBy == "date" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Tarih @if(ViewBag.SortBy == "date") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "employee" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="employee" 
                           asp-route-isDescending="@(ViewBag.SortBy == "employee" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Personel @if(ViewBag.SortBy == "employee") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "customer" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="customer" 
                           asp-route-isDescending="@(ViewBag.SortBy == "customer" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Musteri @if(ViewBag.SortBy == "customer") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Aktivite</th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "product" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="product" 
                           asp-route-isDescending="@(ViewBag.SortBy == "product" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Urun @if(ViewBag.SortBy == "product") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Tahsilat</th>
                    <th>APE</th>
                    <th>Toplu Para</th>
                    <th>Aylik</th>
                    <th>Prim</th>
                    <th>Uretim</th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "amount" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="amount" 
                           asp-route-isDescending="@(ViewBag.SortBy == "amount" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Satis @if(ViewBag.SortBy == "amount") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "count" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="count" 
                           asp-route-isDescending="@(ViewBag.SortBy == "count" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-employeeId="@ViewBag.EmployeeId">
                            Adet @if(ViewBag.SortBy == "count") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Not</th>
                </tr>
            </thead>
            <tbody>
                <tr id="sale-insert-row" class="inline-entry-row" style="display:none;">
                    <td><span class="muted">Yeni</span></td>
                    <td><input data-field="saleDate" type="date" class="cell-input" value="@Model.NewSale.SaleDate.ToString("yyyy-MM-dd")" /></td>
                    <td>
                        @if (canManageAll)
                        {
                            <select data-field="employeeId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var employee in employees)
                                {
                                    <option value="@employee.Id">@employee.FullName</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="hidden" data-field="employeeId" value="@Model.NewSale.EmployeeId" />
                            <span class="pill">@employees.FirstOrDefault()?.FullName</span>
                        }
                    </td>
                    <td>
                        <select data-field="accountId" class="cell-input cell-select">
                            <option value="">Sec</option>
                            @foreach (var account in accounts)
                            {
                                <option value="@account.Id">@account.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="activityId" class="cell-input cell-select">
                            <option value="">Bagimsiz</option>
                            @foreach (var activity in activities)
                            {
                                <option value="@activity.Id">@activity.Code</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="productTypeId" class="cell-input cell-select">
                            @foreach (var type in (List<InsuranceManagement.Web.Domain.InsuranceProductType>)ViewBag.ProductTypes)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </td>
                    <td><input data-field="collectionAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="apeAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="lumpSumAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="monthlyPaymentAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="premiumAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="productionAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="saleAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="saleCount" type="number" min="1" step="1" class="cell-input" value="1" /></td>
                    <td><input data-field="notes" class="cell-input" placeholder="Not" /></td>
                </tr>
                @foreach (var sale in Model.Items)
                {
                    <tr data-sale-id="@sale.Id">
                        <td><a asp-action="Details" asp-route-id="@sale.Id">@sale.Code</a></td>
                        <td><input data-field="saleDate" type="date" class="cell-input" value="@sale.SaleDate.ToString("yyyy-MM-dd")" /></td>
                        <td>
                            @if (canManageAll)
                            {
                                <select data-field="employeeId" class="cell-input cell-select">
                                    <option value="">Sec</option>
                                    @foreach (var employee in employees)
                                    {
                                        @if (sale.EmployeeId == employee.Id)
                                        {
                                            <option value="@employee.Id" selected>@employee.FullName</option>
                                        }
                                        else
                                        {
                                            <option value="@employee.Id">@employee.FullName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" data-field="employeeId" value="@sale.EmployeeId" />
                                <span class="pill">@employees.FirstOrDefault(x => x.Id == sale.EmployeeId)?.FullName</span>
                            }
                        </td>
                        <td>
                            <select data-field="accountId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var account in accounts)
                                {
                                    @if (sale.AccountId == account.Id)
                                    {
                                        <option value="@account.Id" selected>@account.DisplayName</option>
                                    }
                                    else
                                    {
                                        <option value="@account.Id">@account.DisplayName</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="activityId" class="cell-input cell-select">
                                <option value="">Bagimsiz</option>
                                @foreach (var activity in activities)
                                {
                                    @if (sale.ActivityId == activity.Id)
                                    {
                                        <option value="@activity.Id" selected>@activity.Code</option>
                                    }
                                    else
                                    {
                                        <option value="@activity.Id">@activity.Code</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="productTypeId" class="cell-input cell-select">
                                @foreach (var type in (List<InsuranceManagement.Web.Domain.InsuranceProductType>)ViewBag.ProductTypes)
                                {
                                    <option value="@type.Id" selected="@(sale.ProductTypeId == type.Id)">@type.Name</option>
                                }
                            </select>
                        </td>
                        <td><input data-field="collectionAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.CollectionAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="apeAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.ApeAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="lumpSumAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.LumpSumAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="monthlyPaymentAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.MonthlyPaymentAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="premiumAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.PremiumAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="productionAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.ProductionAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="saleAmount" type="number" step="0.01" min="0" class="cell-input" value="@(sale.SaleAmount?.ToString("F2", System.Globalization.CultureInfo.InvariantCulture))" /></td>
                        <td><input data-field="saleCount" type="number" min="1" step="1" class="cell-input" value="@sale.SaleCount" /></td>
                        <td><input data-field="notes" class="cell-input" value="@sale.Notes" /></td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="summary-row">
                    <td colspan="6" style="text-align:right;"><strong>Sayfa Toplami:</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.CollectionAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.ApeAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.LumpSumAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.MonthlyPaymentAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.PremiumAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.ProductionAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.SaleAmount ?? 0).ToString("N2")</strong></td>
                    <td><strong>@Model.Items.Sum(x => x.SaleCount)</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>
    <div class="page-actions split-actions" style="margin-top:16px;">
        <div class="pager">
            <a class="btn ghost grid-page-link @(Model.CurrentPage == 1 ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@prevPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-employeeId="@ViewBag.EmployeeId"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Onceki</a>
            
            <span class="pill">Sayfa @Model.CurrentPage / @Model.TotalPages</span>
            
            <a class="btn ghost grid-page-link @(Model.CurrentPage == Model.TotalPages ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@nextPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-employeeId="@ViewBag.EmployeeId"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Sonraki</a>
        </div>
        <div class="muted">Toplam @Model.TotalCount kayit</div>
    </div>
</div>

@await Html.PartialAsync("_GridBulkSaveForm", new InsuranceManagement.Web.ViewModels.GridBulkSaveFormViewModel
{
    ActionName = "BulkSave",
    FormId = "sale-bulk-save-form",
    PayloadInputId = "sale-bulk-payload",
    Page = Model.CurrentPage
})

@section Scripts {
    <script>
        function toggleSaleInsertRow() {
            InsuranceGridDraft.toggleRow("sale-insert-row");
        }

        InsuranceGridDraft.create({
            storageKey: "sale-grid-draft-v1",
            rowSelector: "tr[data-sale-id]",
            rowIdAttribute: "data-sale-id",
            insertRowId: "sale-insert-row",
            saveButtonId: "save-all-sales-btn",
            clearButtonId: "clear-sale-draft-btn",
            formId: "sale-bulk-save-form",
            payloadInputId: "sale-bulk-payload",
            clearOnLoad: @(((TempData["ClearGridDraftKey"] as string) == "sale-grid-draft-v1").ToString().ToLowerInvariant())
        });
    </script>
}
