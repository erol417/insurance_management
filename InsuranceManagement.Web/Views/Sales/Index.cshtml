@model InsuranceManagement.Web.ViewModels.SalesIndexViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var accounts = ViewBag.Accounts as List<InsuranceManagement.Web.Domain.Account> ?? [];
    var activities = ViewBag.Activities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
    var canManageAll = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("SalesManager") || User.IsInRole("Operations");
    var prevPage = Math.Max(1, Model.CurrentPage - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
    ViewData["Title"] = "Satislar";
    ViewData["Subtitle"] = "Aktiviteye bagli veya bagimsiz satis kayitlari";
}
<div class="page-actions">
    <button type="button" class="btn primary" onclick="toggleSaleInsertRow()">Yeni Satir Ekle</button>
    <button type="button" class="btn secondary" id="save-all-sales-btn">Degisiklikleri Kaydet</button>
    <button type="button" class="btn ghost" id="clear-sale-draft-btn">Taslagi Temizle</button>
    <a class="btn secondary" asp-action="Create">Detayli Form</a>
</div>
<div class="panel" style="margin-top:18px;">
    <div class="note-box">
        <strong>Grid duzenleme</strong>
        <p>Satis kayitlari bu ekranda tablo uzerinden hizli giris icin duzenlenebilir. Degisiklikler taslakta tutulur ve tek kaydetme ile islenir.</p>
        <p>Urun tipine gore zorunlu finansal alanlar yine korunur. Sayfalar arasinda gezsen de taslak kaybolmaz.</p>
    </div>
    <div class="table-scroll">
        <table class="table compact-table">
            <thead>
                <tr>
                    <th>Kod</th>
                    <th>Tarih</th>
                    <th>Personel</th>
                    <th>Musteri</th>
                    <th>Aktivite</th>
                    <th>Urun</th>
                    <th>Tahsilat</th>
                    <th>APE</th>
                    <th>Toplu Para</th>
                    <th>Aylik</th>
                    <th>Prim</th>
                    <th>Uretim</th>
                    <th>Satis</th>
                    <th>Adet</th>
                    <th>Not</th>
                </tr>
            </thead>
            <tbody>
                <tr id="sale-insert-row" class="inline-entry-row" style="display:none;">
                    <td><span class="muted">Yeni</span></td>
                    <td><input data-field="saleDate" type="date" class="cell-input" value="@Model.NewSale.SaleDate.ToString("yyyy-MM-dd")" /></td>
                    <td>
                        @if (canManageAll)
                        {
                            <select data-field="employeeId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var employee in employees)
                                {
                                    <option value="@employee.Id">@employee.FullName</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="hidden" data-field="employeeId" value="@Model.NewSale.EmployeeId" />
                            <span class="pill">@employees.FirstOrDefault()?.FullName</span>
                        }
                    </td>
                    <td>
                        <select data-field="accountId" class="cell-input cell-select">
                            <option value="">Sec</option>
                            @foreach (var account in accounts)
                            {
                                <option value="@account.Id">@account.DisplayName</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="activityId" class="cell-input cell-select">
                            <option value="">Bagimsiz</option>
                            @foreach (var activity in activities)
                            {
                                <option value="@activity.Id">@activity.Code</option>
                            }
                        </select>
                    </td>
                    <td>
                        <select data-field="productType" class="cell-input cell-select">
                            @foreach (InsuranceManagement.Web.Domain.ProductType type in Enum.GetValues(typeof(InsuranceManagement.Web.Domain.ProductType)))
                            {
                                <option value="@type">@type.ToDisplayText()</option>
                            }
                        </select>
                    </td>
                    <td><input data-field="collectionAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="apeAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="lumpSumAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="monthlyPaymentAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="premiumAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="productionAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="saleAmount" type="number" step="0.01" min="0" class="cell-input" /></td>
                    <td><input data-field="saleCount" type="number" min="1" step="1" class="cell-input" value="1" /></td>
                    <td><input data-field="notes" class="cell-input" placeholder="Not" /></td>
                </tr>
                @foreach (var sale in Model.Items)
                {
                    <tr data-sale-id="@sale.Id">
                        <td><a asp-action="Details" asp-route-id="@sale.Id">@sale.Code</a></td>
                        <td><input data-field="saleDate" type="date" class="cell-input" value="@sale.SaleDate.ToString("yyyy-MM-dd")" /></td>
                        <td>
                            @if (canManageAll)
                            {
                                <select data-field="employeeId" class="cell-input cell-select">
                                    <option value="">Sec</option>
                                    @foreach (var employee in employees)
                                    {
                                        @if (sale.EmployeeId == employee.Id)
                                        {
                                            <option value="@employee.Id" selected>@employee.FullName</option>
                                        }
                                        else
                                        {
                                            <option value="@employee.Id">@employee.FullName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" data-field="employeeId" value="@sale.EmployeeId" />
                                <span class="pill">@employees.FirstOrDefault(x => x.Id == sale.EmployeeId)?.FullName</span>
                            }
                        </td>
                        <td>
                            <select data-field="accountId" class="cell-input cell-select">
                                <option value="">Sec</option>
                                @foreach (var account in accounts)
                                {
                                    @if (sale.AccountId == account.Id)
                                    {
                                        <option value="@account.Id" selected>@account.DisplayName</option>
                                    }
                                    else
                                    {
                                        <option value="@account.Id">@account.DisplayName</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="activityId" class="cell-input cell-select">
                                <option value="">Bagimsiz</option>
                                @foreach (var activity in activities)
                                {
                                    @if (sale.ActivityId == activity.Id)
                                    {
                                        <option value="@activity.Id" selected>@activity.Code</option>
                                    }
                                    else
                                    {
                                        <option value="@activity.Id">@activity.Code</option>
                                    }
                                }
                            </select>
                        </td>
                        <td>
                            <select data-field="productType" class="cell-input cell-select">
                                @foreach (InsuranceManagement.Web.Domain.ProductType type in Enum.GetValues(typeof(InsuranceManagement.Web.Domain.ProductType)))
                                {
                                    @if (sale.ProductType == type)
                                    {
                                        <option value="@type" selected>@type.ToDisplayText()</option>
                                    }
                                    else
                                    {
                                        <option value="@type">@type.ToDisplayText()</option>
                                    }
                                }
                            </select>
                        </td>
                        <td><input data-field="collectionAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.CollectionAmount?.ToString()" /></td>
                        <td><input data-field="apeAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.ApeAmount?.ToString()" /></td>
                        <td><input data-field="lumpSumAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.LumpSumAmount?.ToString()" /></td>
                        <td><input data-field="monthlyPaymentAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.MonthlyPaymentAmount?.ToString()" /></td>
                        <td><input data-field="premiumAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.PremiumAmount?.ToString()" /></td>
                        <td><input data-field="productionAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.ProductionAmount?.ToString()" /></td>
                        <td><input data-field="saleAmount" type="number" step="0.01" min="0" class="cell-input" value="@sale.SaleAmount?.ToString()" /></td>
                        <td><input data-field="saleCount" type="number" min="1" step="1" class="cell-input" value="@sale.SaleCount" /></td>
                        <td><input data-field="notes" class="cell-input" value="@sale.Notes" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="page-actions split-actions">
        <div class="pager">
            <a class="btn ghost grid-page-link @(Model.CurrentPage == 1 ? "disabled-link" : "")" asp-action="Index" asp-route-page="@prevPage" asp-route-pageSize="@Model.PageSize">Onceki</a>
            <span class="pill">Sayfa @Model.CurrentPage / @Model.TotalPages</span>
            <a class="btn ghost grid-page-link @(Model.CurrentPage == Model.TotalPages ? "disabled-link" : "")" asp-action="Index" asp-route-page="@nextPage" asp-route-pageSize="@Model.PageSize">Sonraki</a>
        </div>
        <div class="muted">Toplam @Model.TotalCount kayit</div>
    </div>
</div>

@await Html.PartialAsync("_GridBulkSaveForm", new InsuranceManagement.Web.ViewModels.GridBulkSaveFormViewModel
{
    ActionName = "BulkSave",
    FormId = "sale-bulk-save-form",
    PayloadInputId = "sale-bulk-payload",
    Page = Model.CurrentPage
})

@section Scripts {
    <script>
        function toggleSaleInsertRow() {
            InsuranceGridDraft.toggleRow("sale-insert-row");
        }

        InsuranceGridDraft.create({
            storageKey: "sale-grid-draft-v1",
            rowSelector: "tr[data-sale-id]",
            rowIdAttribute: "data-sale-id",
            insertRowId: "sale-insert-row",
            saveButtonId: "save-all-sales-btn",
            clearButtonId: "clear-sale-draft-btn",
            formId: "sale-bulk-save-form",
            payloadInputId: "sale-bulk-payload",
            clearOnLoad: @(((TempData["ClearGridDraftKey"] as string) == "sale-grid-draft-v1").ToString().ToLowerInvariant())
        });
    </script>
}
