@model InsuranceManagement.Web.ViewModels.SaleFormViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var accounts = ViewBag.Accounts as List<InsuranceManagement.Web.Domain.Account> ?? [];
    var activities = ViewBag.Activities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
    ViewData["Title"] = "Satis Duzenle";
    ViewData["Subtitle"] = "Satis kaydini guncelle";
}

<div class="form-layout">
    <div class="layout-main">
        <section class="section-block">
            <h3>Satis Bilgileri</h3>
            <form method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="validation-summary-errors"></div>
                <div class="form-grid three">
                    <div class="field"><label asp-for="SaleDate"></label><input asp-for="SaleDate" type="date" /></div>
                    <div class="field"><label asp-for="EmployeeId"></label><select asp-for="EmployeeId">@foreach (var employee in employees){<option value="@employee.Id">@employee.FullName</option>}</select></div>
                    <div class="field"><label asp-for="AccountId"></label><select asp-for="AccountId">@foreach (var account in accounts){<option value="@account.Id">@account.DisplayName</option>}</select></div>
                    <div class="field"><label asp-for="ActivityId"></label><select asp-for="ActivityId"><option value="">Bagimsiz satis</option>@foreach (var activity in activities){<option value="@activity.Id">@activity.Code</option>}</select></div>
                    <div class="field">
                        <label>Urun Tipi</label>
                        <select asp-for="ProductTypeId">
                            @foreach (var type in (List<InsuranceManagement.Web.Domain.InsuranceProductType>)ViewBag.ProductTypes)
                            {
                                <option value="@type.Id">@type.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field"><label asp-for="SaleCount"></label><input asp-for="SaleCount" /></div>
                    <div class="field"><label asp-for="CollectionAmount"></label><input asp-for="CollectionAmount" /></div>
                    <div class="field"><label asp-for="ApeAmount"></label><input asp-for="ApeAmount" /></div>
                    <div class="field"><label asp-for="LumpSumAmount"></label><input asp-for="LumpSumAmount" /></div>
                    <div class="field"><label asp-for="MonthlyPaymentAmount"></label><input asp-for="MonthlyPaymentAmount" /></div>
                    <div class="field"><label asp-for="PremiumAmount"></label><input asp-for="PremiumAmount" /></div>
                    <div class="field"><label asp-for="ProductionAmount"></label><input asp-for="ProductionAmount" /></div>
                    <div class="field"><label asp-for="SaleAmount"></label><input asp-for="SaleAmount" /></div>
                </div>
                <div class="field"><label asp-for="Notes"></label><textarea asp-for="Notes"></textarea></div>
                <div class="page-actions"><button type="submit" class="btn primary">Guncelle</button></div>
            </form>
        </section>
    </div>
    <aside class="side-stack">
        <section class="side-panel soft">
            <h3>Baglamsal Aksiyonlar ve Rehber</h3>
        </section>
        <section class="side-panel">
            <h4 style="margin-bottom:14px;">Hizli Aksiyonlar</h4>
            <div class="action-buttons">
                <button class="btn primary" type="button">Tahsilat Kontrolu</button>
                <button class="btn primary" type="button">Aktivite Karti</button>
            </div>
        </section>
        <section class="side-panel soft">
            <h4 style="margin-bottom:16px;">Duzenleme Rehberi</h4>
            <div class="timeline">
                <div class="timeline-item">
                    <strong>Finansal tutarlilik</strong>
                    <div>Tahsilat, prim ve uretim alanlari urun tipine gore birbiriyle uyumlu olmali; raporlar bu alanlardan beslenir.</div>
                </div>
                <div class="timeline-item">
                    <strong>Bagli kayitlar</strong>
                    <div>Aktivite veya musteri baglantisi degistirilirse ilgili performans ve ziyaret raporlari da etkilenir.</div>
                </div>
                <div class="timeline-item">
                    <strong>Sonraki adim</strong>
                    <div>Duzenleme tamamlaninca belge kontrolu ve tahsilat akislarini tekrar gozden gecir.</div>
                </div>
            </div>
        </section>
    </aside>
</div>
