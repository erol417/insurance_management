@model dynamic

<form method="get" class="dashboard-filters" id="dashboardFilter">
    <div class="dashboard-filters-inner">
        <i data-lucide="filter" class="filter-icon"></i>
        
        <select name="range" class="filter-select-minimal" onchange="this.form.submit()">
            <option value="thisweek" selected="@(Model.DateRange == "thisweek")">Bu Hafta</option>
            <option value="thismonth" selected="@(Model.DateRange == "thismonth")">Bu Ay</option>
            <option value="last30" selected="@(Model.DateRange == "last30")">Son 30 Gün</option>
            <option value="last90" selected="@(Model.DateRange == "last90")">Son 90 Gün</option>
            <option value="thisyear" selected="@(Model.DateRange == "thisyear")">Bu Yıl</option>
            <option value="custom" selected="@(Model.DateRange == "custom")">Özel Aralık</option>
        </select>

        <div class="v-divider"></div>

        <select name="employeeId" class="filter-select-minimal" onchange="this.form.submit()">
            <option value="">Tum Personel</option>
            @foreach (var item in Model.PersonnelList)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>

        <div class="v-divider"></div>

        <select name="productTypeId" class="filter-select-minimal" onchange="this.form.submit()">
            <option value="">Tum Urunler</option>
            @foreach (var item in Model.ProductTypeList)
            {
                <option value="@item.Value" selected="@item.Selected">@item.Text</option>
            }
        </select>

        @if (Model.DateRange == "custom")
        {
            <div class="custom-date-inputs">
                <input type="date" name="start" value="@Model.StartDate.ToString("yyyy-MM-dd")" class="filter-input-date" onchange="this.form.submit()" />
                <input type="date" name="end" value="@Model.EndDate.ToString("yyyy-MM-dd")" class="filter-input-date" onchange="this.form.submit()" />
            </div>
        }
    </div>
</form>
