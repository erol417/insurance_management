@using InsuranceManagement.Web.ViewModels
@using Microsoft.AspNetCore.Routing
@{
    var shell = ViewBag.AppShell as AppShellViewModel ?? new AppShellViewModel();
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var navigationLabels = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
    {
        ["Dashboard"] = "Dashboard",
        ["Leads"] = "Leadler",
        ["Accounts"] = "Musteriler",
        ["Activities"] = "Aktiviteler",
        ["Sales"] = "Satislar",
        ["Expenses"] = "Masraflar",
        ["Employees"] = "Personeller",
        ["Admin"] = "Yonetim",
        ["Imports"] = "Veri Aktarımı",
        ["Help"] = "Yardım"
    };

    var topNavItems = shell.Groups
        .Where(x => x.Title != "Kisisel")
        .SelectMany(x => x.Items)
        .Where(x => !string.IsNullOrWhiteSpace(x.Controller))
        .GroupBy(x => x.Controller!, StringComparer.OrdinalIgnoreCase)
        .Select(g =>
        {
            var first = g.First();
            var label = navigationLabels.TryGetValue(g.Key, out var mappedLabel) ? mappedLabel : first.Label;
            return new { Controller = first.Controller, Action = first.Action, Label = label, RouteValues = (object?)null };
        })
        .ToList();

    var kisiselGroup = shell.Groups.FirstOrDefault(x => x.Title == "Kisisel");

    var subNavControllers = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Dashboard",
        "Leads",
        "Admin",
        "Imports"
    };

    var currentGroup = shell.Groups.FirstOrDefault(g => g.Items.Any(i => string.Equals(i.Controller, controller, StringComparison.OrdinalIgnoreCase)));
    var subNavItems = currentGroup?.Items
        .Where(i => !string.IsNullOrWhiteSpace(i.Controller) && !string.IsNullOrWhiteSpace(i.Action))
        .ToList() ?? [];
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Sigorta Operasyon</title>
    <!-- Modern Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@500;600;700&display=swap" rel="stylesheet">
    
    <!-- Professional Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var iconMapping = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase)
        {
            ["Dashboard"] = "layout-dashboard",
            ["Leads"] = "users",
            ["Accounts"] = "building-2",
            ["Activities"] = "list-todo",
            ["Sales"] = "file-spreadsheet",
            ["Expenses"] = "receipt",
            ["Employees"] = "user-round-cog",
            ["Admin"] = "settings",
            ["Imports"] = "upload-cloud",
            ["Help"] = "help-circle",
            ["Kisisel"] = "user"
        };
    }
    <div class="app-shell">
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="brand-lockup">
                    <div class="brand-icon-new">
                        <i data-lucide="shield-check"></i>
                    </div>
                    <div class="brand-title">
                        Sigorta <span>Operasyon</span>
                        <small>@(shell.CurrentRole?.ToDisplayText() ?? "MVP")</small>
                    </div>
                </div>
            </div>
            <nav class="sidebar-nav">
                @if (kisiselGroup != null)
                {
                    @foreach (var item in kisiselGroup.Items)
                    {
                        var activeClass = string.Equals(controller, item.Controller, StringComparison.OrdinalIgnoreCase) && string.Equals(action, item.Action, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
                        var routeData = item.RouteValues != null ? new RouteValueDictionary(item.RouteValues).ToDictionary(x => x.Key, x => x.Value?.ToString() ?? string.Empty) : null;
                        var icon = iconMapping.TryGetValue(item.Controller ?? "Kisisel", out var ic) ? ic : "circle";
                        <a class="@activeClass" asp-controller="@item.Controller" asp-action="@item.Action" asp-all-route-data="routeData">
                            <i data-lucide="@icon"></i>
                            <span>@item.Label</span>
                        </a>
                    }
                }
                
                <div style="height: 1px; background: var(--line); margin: 8px 16px;"></div>

                @foreach (var item in topNavItems)
                {
                    var activeClass = string.Equals(controller, item.Controller, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
                    var icon = iconMapping.TryGetValue(item.Controller ?? string.Empty, out var ic) ? ic : "circle";
                    <a class="@activeClass" asp-controller="@item.Controller" asp-action="@item.Action">
                        <i data-lucide="@icon"></i>
                        <span>@item.Label</span>
                    </a>
                }
            </nav>
            <div class="sidebar-footer">
                <form asp-controller="Auth" asp-action="Logout" method="post" class="inline-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn secondary" style="width: 100%; display: flex; align-items: center; gap: 8px; justify-content: center;">
                        <i data-lucide="log-out" style="width: 16px;"></i>
                        Cikis Yap
                    </button>
                </form>
            </div>
        </aside>

        <div class="main-content">
            <div class="sidebar-overlay" id="sidebarOverlay"></div>
            <header class="topbar">
                <div class="topbar-left">
                    <button class="menu-toggle" id="sidebarToggle">
                        <i data-lucide="menu"></i>
                    </button>
                    <div class="search-input-wrapper">
                        <i data-lucide="search"></i>
                        <input class="search-input" placeholder="Hızlıca ara..." />
                    </div>
                </div>
                <div class="topbar-right">
                    <a asp-controller="Help" asp-action="Index" style="display:flex; align-items:center; justify-content:center; width:36px; height:36px; border-radius:50%; background:#f1f5f9; color:var(--text); text-decoration:none;" title="Yardım Merkezi">
                        <i data-lucide="help-circle" style="width:18px;"></i>
                    </a>
                    <div class="user-lockup" id="userMenuTrigger">
                        <div class="avatar"></div>
                        <div style="font-weight: 500; font-size: 14px;">@shell.FullName</div>
                        <i data-lucide="chevron-down" style="width: 14px; color: var(--muted);"></i>

                        <div class="user-dropdown" id="userDropdown">
                            @if (shell.CurrentEmployeeId.HasValue)
                            {
                                <a asp-controller="Employees" asp-action="Details" asp-route-id="@shell.CurrentEmployeeId">
                                    <i data-lucide="user"></i>
                                    Profilim
                                </a>
                                <a asp-controller="Employees" asp-action="Edit" asp-route-id="@shell.CurrentEmployeeId">
                                    <i data-lucide="user-cog"></i>
                                    Hesabımı Düzenle
                                </a>
                            }
                            <div class="divider"></div>
                            <form asp-controller="Auth" asp-action="Logout" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit">
                                    <i data-lucide="log-out"></i>
                                    Güvenli Çıkış
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </header>

            <main class="page">
                <div class="page-inner">
                    @if (subNavControllers.Contains(controller ?? string.Empty) && subNavItems.Count > 1)
                    {
                        <nav class="subnav">
                            @foreach (var item in subNavItems)
                            {
                                var subActiveClass = string.Equals(controller, item.Controller, StringComparison.OrdinalIgnoreCase)
                                    && string.Equals(action, item.Action, StringComparison.OrdinalIgnoreCase)
                                    ? "active"
                                    : string.Empty;
                                var subRouteData = item.RouteValues != null 
                                    ? new RouteValueDictionary(item.RouteValues).ToDictionary(x => x.Key, x => x.Value?.ToString() ?? string.Empty) 
                                    : null;
                                <a class="@subActiveClass" asp-controller="@item.Controller" asp-action="@item.Action" asp-all-route-data="subRouteData">@item.Label</a>
                            }
                        </nav>
                    }
                    <div class="page-header">
                        <div class="breadcrumb">@(navigationLabels.TryGetValue(controller ?? string.Empty, out var breadcrumbLabel) ? breadcrumbLabel : (controller ?? "Ana Sayfa")) / @(ViewData["Title"] ?? action ?? "Dashboard")</div>
                        <h1>@ViewData["Title"]</h1>
                        @if (ViewData["Subtitle"] is string subtitle && !string.IsNullOrWhiteSpace(subtitle))
                        {
                            <p>@subtitle</p>
                        }
                    </div>
                    @if (TempData["Flash"] is string flash)
                    {
                        <div class="flash">@flash</div>
                    }
                    @if (TempData["Warning"] is string warning)
                    {
                        <div class="note-box" style="margin-bottom:16px;"><strong>Uyari</strong><p>@warning</p></div>
                    }
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/gridDraft.js" asp-append-version="true"></script>
    <script>
        lucide.createIcons();

        // Constants
        const shell = document.querySelector('.app-shell');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        const userMenuTrigger = document.getElementById('userMenuTrigger');
        const userDropdown = document.getElementById('userDropdown');

        // Sidebar Toggle (Mobile)
        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', () => {
                shell.classList.add('sidebar-open');
            });
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', () => {
                shell.classList.remove('sidebar-open');
            });
        }

        // User Dropdown Toggle
        if (userMenuTrigger && userDropdown) {
            userMenuTrigger.addEventListener('click', (e) => {
                e.stopPropagation();
                userDropdown.classList.toggle('show');
            });

            document.addEventListener('click', (e) => {
                if (!userMenuTrigger.contains(e.target)) {
                    userDropdown.classList.remove('show');
                }
            });
        }

        // Close sidebar on navigation (mobile)
        document.querySelectorAll('.sidebar-nav a').forEach(link => {
            link.addEventListener('click', () => {
                shell.classList.remove('sidebar-open');
            });
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
