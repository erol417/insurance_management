@{
    ViewData["Title"] = "Referans Veriler";
    ViewData["Subtitle"] = "MVP referans veri notlari";
}

<div class="premium-strip">
    <div>
        <strong>Referans Veri Ozeti</strong>
        <span>Aktivite, urun ve masraf yapilarini tek bakista gormek icin sade yonetim ekrani.</span>
    </div>
    <div class="inline-actions">
        <span class="pill">cekirdek tanimlar</span>
    </div>
</div>

<div class="report-grid two-up">
    <section class="report-card">
        <div class="section-title">
            <h3>Aktivite Durumlari</h3>
            <span class="pill">iki asamali</span>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <strong>Contact</strong>
                <div>Contacted / NotContacted</div>
            </div>
            <div class="timeline-item">
                <strong>Outcome</strong>
                <div>Positive / Negative / Postponed / SaleClosed</div>
            </div>
        </div>
    </section>
    <section class="report-card">
        <div class="section-title">
            <h3>Urun ve Masraf</h3>
            <span class="pill">MVP</span>
        </div>
        <div class="timeline">
            <div class="timeline-item">
                <strong>Urunler</strong>
                <div>BES, Life, Health, Travel, Other</div>
            </div>
            <div class="timeline-item">
                <strong>Masraf Turleri</strong>
                <div>Travel, Meal, Accommodation, Other</div>
            </div>
        </div>
    </section>
</div>
