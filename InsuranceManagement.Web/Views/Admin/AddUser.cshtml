@model InsuranceManagement.Web.Domain.UserAccount
@using InsuranceManagement.Web.Domain
@{
    ViewData["Title"] = "Yeni Sistem Hesabi";
}

<div class="premium-strip">
    <div style="display:flex; justify-content:space-between; width:100%; align-items:center;">
        <div>
            <strong>Yeni Sistem Hesabi (Personel Harici)</strong>
            <span>IT, Destek veya Denetçi gibi sadece sistem erişimi olan hesaplar ekleyin.</span>
        </div>
        <a asp-action="Users" class="btn primary-outline" style="background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2);">
             Listeye Don
        </a>
    </div>
</div>

<div class="add-container" style="max-width:850px; margin:40px auto; display:grid; grid-template-columns: 320px 1fr; gap:32px;">
    
    <!-- Bilgilendirme Kartı -->
    <div class="info-sidebar">
        <div class="card" style="background:#f0f9ff; border:1px solid #bae6fd; border-radius:24px; padding:28px; position:sticky; top:20px;">
            <div style="font-size:28px; margin-bottom:16px;">🖥️</div>
            <h4 style="color:#0369a1; font-size:16px; margin-bottom:12px; font-weight:700;">Sistem Hesabı Nedir?</h4>
            <p style="font-size:13px; color:#0c4a6e; line-height:1.6; margin-bottom:16px;">
                Bu bölümden oluşturulan hesaplar <strong>Sistem Uzmanı</strong> yetkisine sahip olur ve herhangi bir personel kaydıyla (Maaş, Şehir, Bölge) ilişkilendirilmez.
            </p>
            <div style="margin-top:20px; padding:16px; background:rgba(255,255,255,0.5); border-radius:16px; border:1px solid #bae6fd;">
                <span style="font-size:11px; font-weight:700; color:#0369a1; text-transform:uppercase;">💡 Önemli Not</span>
                <p style="font-size:12px; color:#0369a1; margin-top:4px;">
                    Satış personeli veya müdürlerin giriş yetkileri kendi profillerinden yönetilir. Burası sadece IT ve Denetim yetkilileri içindir.
                </p>
            </div>
        </div>
    </div>

    <!-- Kayıt Formu -->
    <div class="card" style="background:#fff; border-radius:26px; padding:32px; box-shadow:0 25px 50px -12px rgba(0,0,0,0.08); border:1px solid #eeeff2;">
        <form asp-action="AddUser" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group" style="margin-bottom:24px;">
                <label style="display:block; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:10px;">Tam Ad Soyad</label>
                <input type="text" name="fullName" placeholder="Örn: Erol Güneş" required
                       style="width:100%; padding:15px 20px; border-radius:14px; border:1px solid #e2e8f0; font-size:15px; background:#f8fafc; outline:none; transition:all 0.2s;" />
            </div>

            <div class="form-row" style="display:flex; gap:20px; margin-bottom:24px;">
                <div class="form-group" style="flex:1;">
                    <label style="display:block; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:10px;">Kullanici Adi</label>
                    <input type="text" name="userName" placeholder="erolgunes" required
                           style="width:100%; padding:15px 20px; border-radius:14px; border:1px solid #e2e8f0; font-size:15px; background:#f8fafc; outline:none;" />
                </div>
                <div class="form-group" style="flex:1;">
                    <label style="display:block; font-size:12px; font-weight:700; color:#64748b; text-transform:uppercase; margin-bottom:10px;">Baslangıc Sifresi</label>
                    <input type="password" name="password" placeholder="••••••••" required
                           style="width:100%; padding:15px 20px; border-radius:14px; border:1px solid #e2e8f0; font-size:15px; background:#f8fafc; outline:none;" />
                </div>
            </div>

            <!-- Gizli Rol/Personel (Arka planda atanır) -->
            <div style="background:#f1f5f9; padding:16px; border-radius:16px; margin-bottom:32px; display:flex; align-items:center; gap:12px;">
                <div style="font-size:18px;">🛠️</div>
                <div style="font-size:13px; color:#475569;">
                    Bu kullanıcı otomatik olarak <strong>Sistem Uzmanı</strong> rolüyle oluşturulacaktır.
                </div>
            </div>

            <div style="display:flex; gap:16px;">
                <button type="submit" class="btn primary" style="flex:1; padding:16px; font-weight:700; border-radius:16px; box-shadow:0 10px 20px -5px rgba(37,99,235,0.4); background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);">
                    🚀 Sistem Hesabını Olustur
                </button>
                <a asp-action="Users" class="btn ghost" style="padding:16px 32px; font-weight:600; color:#64748b;">Vazgeç</a>
            </div>
        </form>
    </div>
</div>

<style>
    input:focus { border-color: #3b82f6 !important; background: #fff !important; box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1); }
    .premium-strip { background: linear-gradient(135deg, #1e293b 0%, #334155 100%); color: white; padding: 24px 32px; border-radius: 20px; margin-bottom: 24px; }
</style>
