@model IEnumerable<InsuranceManagement.Web.Domain.RolePermission>
@using InsuranceManagement.Web.Domain
@{
    var permissions = Model.ToList();
    var roleTypes = Enum.GetValues<RoleType>();
    ViewData["Title"] = "Rol ve Yetki Yonetimi";
    ViewData["Subtitle"] = "Kimin ne yapabildiğini dinamik olarak yönetin";
}

<div class="premium-strip">
    <div style="display:flex; justify-content:space-between; width:100%; align-items:center;">
        <div>
            <strong>Canli Yetki Paneli</strong>
            <span>Yetkileri düzenleyin ve toplu olarak kaydedin.</span>
        </div>
        <div class="inline-actions" style="display:flex; gap:12px; align-items:center;">
             <form asp-action="SyncPermissions" method="post" style="display:inline;">
                <button type="submit" class="btn warning-outline" style="display: flex; align-items: center; gap: 8px; background:rgba(245,158,11,0.1); border:1px solid rgba(245,158,11,0.3); color:#d97706; font-weight:600;">
                    <i data-lucide="refresh-cw" style="width: 16px; height: 16px;"></i> Yetkileri Yenile
                </button>
            </form>
            <a asp-action="Users" class="btn primary-outline" style="display: flex; align-items: center; gap: 8px; background:rgba(255,255,255,0.1); border:1px solid rgba(255,255,255,0.2);">
                <i data-lucide="users" style="width: 16px; height: 16px;"></i> Kullanicilara Don
            </a>
        </div>
    </div>
</div>

<div class="role-explorer-container" style="margin-top:24px; display:grid; grid-template-columns: 280px 1fr; gap:24px; min-height:600px;">
    
    <!-- Sidebar -->
    <aside class="role-sidebar" style="background:#fff; border-radius:16px; padding:16px; box-shadow:0 10px 30px rgba(0,0,0,0.05); border:1px solid #eeeff2;">
        <h4 style="margin-bottom:16px; padding-left:8px; color:#64748b; font-size:12px; text-transform:uppercase; letter-spacing:0.5px;">Sistem Rolleri</h4>
        <div class="role-nav-list" style="display:flex; flex-direction:column; gap:8px;">
            @foreach(var role in roleTypes)
            {
                <div class="role-nav-item @(role == RoleType.Admin ? "active" : "")" onclick="selectRole('@role')" id="nav-@role" style="padding:12px 16px; border-radius:12px; cursor:pointer; display:flex; align-items:center; gap:12px; transition:all 0.2s ease;">
                    <i data-lucide="shield-check" style="width: 18px; height: 18px; color: var(--brand);"></i>
                    <strong style="color:#1e293b;">@role.ToDisplayText()</strong>
                </div>
            }
        </div>
    </aside>

    <!-- Content -->
    <main class="permission-view" style="background:#fff; border-radius:16px; padding:32px; box-shadow:0 10px 30px rgba(0,0,0,0.05); border:1px solid #eeeff2;">
        
        @foreach(var role in roleTypes)
        {
            var rolePerms = permissions.Where(x => x.Role == role).OrderBy(x => x.ModuleName).ToList();
            <div id="content-@role" class="role-content-pane" style="display:@(role == RoleType.Admin ? "block" : "none"); animation: fadeIn 0.3s ease;">
                <form asp-action="UpdateRolePermissions" method="post">
                    @Html.AntiForgeryToken()
                    
                    <div class="role-header" style="display:flex; justify-content:space-between; align-items:center; margin-bottom:32px; padding-bottom:24px; border-bottom:1px solid #f1f5f9;">
                        <div style="display:flex; align-items:center; gap:20px;">
                            <div style="width:64px; height:64px; background:var(--brand); border-radius:16px; display:flex; align-items:center; justify-content:center; font-size:32px; color:white;">
                                <i data-lucide="shield" style="width: 32px; height: 32px;"></i>
                            </div>
                            <div>
                                <h2 style="margin:0; color:#0f172a; font-size:24px;">@role.ToDisplayText() Yetkileri</h2>
                                <p style="margin:4px 0 0; color:#475569;">Degisiklikleri yapip sağdaki butona basarak kaydedin.</p>
                            </div>
                        </div>
                        <button type="submit" class="btn primary" style="padding:12px 24px; font-weight:600; box-shadow:0 10px 15px -3px rgba(37,99,235,0.3);">
                            💾 Tumunu Kaydet
                        </button>
                    </div>

                    <div class="permission-grid" style="display:grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap:20px;">
                        @for(int i=0; i < rolePerms.Count; i++)
                        {
                            var p = rolePerms[i];
                            <div class="perm-card" style="padding:20px; border-radius:16px; border:1px solid #e2e8f0; background:#fff; transition:all 0.2s ease;">
                                <input type="hidden" name="updates[@i].Id" value="@p.Id" />
                                
                                <div style="display:flex; justify-content:space-between; margin-bottom:12px;">
                                    <div style="display:flex; align-items:center; gap:10px;">
                                        <i data-lucide="@p.Icon" style="width: 20px; height: 20px; color: #64748b;"></i>
                                        <strong style="color:#334155;">@p.ModuleName</strong>
                                    </div>
                                    <div class="toggle-switch @(p.ModuleKey == "Admin" && role != RoleType.Admin ? "disabled-toggle" : "")">
                                        <input type="checkbox" name="updates[@i].IsAllowed" value="true" @(p.IsAllowed ? "checked" : "") 
                                               @(p.ModuleKey == "Admin" && role != RoleType.Admin ? "disabled" : "")
                                               id="check-@p.Id" />
                                        <label for="check-@p.Id"></label>
                                        <input type="hidden" name="updates[@i].IsAllowed" value="false" />
                                    </div>
                                </div>

                                @if (p.ModuleKey == "Admin" && role != RoleType.Admin)
                                {
                                    <div style="margin-bottom:12px; padding:8px 12px; background:rgba(239, 68, 68, 0.05); border-radius:8px; border:1px dashed rgba(239, 68, 68, 0.2); display:flex; align-items:center; gap:8px;">
                                        <i data-lucide="alert-triangle" style="width:14px; height:14px; color:#ef4444;"></i>
                                        <span style="font-size:11px; color:#b91c1c; font-weight:500;">Sistem Korumasi: Bu modul sadece Admin roluyle sınırlıdır.</span>
                                    </div>
                                }

                                <div class="field-compact" style="margin-bottom:12px;">
                                    <label style="font-size:10px; color:#94a3b8; text-transform:uppercase; font-weight:700;">Yetki Seviyesi</label>
                                    <select name="updates[@i].AccessLevel" style="width:100%; border:none; background:#f8fafc; padding:8px 10px; border-radius:6px; font-size:13px; color:#1e293b; cursor:pointer;">
                                        @{
                                            var levels = new[] { "Tam Yetki", "Sadece Izleme", "Kendi Kayitlari", "Ekip Kayitlari", "Hizli Giris", "Veri Analitigi", "Dosya Yukleme", "Yasakli" };
                                            foreach(var level in levels)
                                            {
                                                <!option value="@level" @(p.AccessLevel == level ? "selected" : "")>@level</!option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="field-compact">
                                    <label style="font-size:10px; color:#94a3b8; text-transform:uppercase; font-weight:700;">Yardim Metni (Bos birakilirsa otomatik atanir)</label>
                                    <textarea name="updates[@i].Tooltip" style="width:100%; border:none; background:#f8fafc; padding:6px 10px; border-radius:6px; font-size:12px; height:60px; resize:none;">@p.Tooltip</textarea>
                                </div>
                            </div>
                        }
                    </div>
                </form>
            </div>
        }

        <div id="role-empty-state" style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;">
            <div style="font-size:64px; margin-bottom:16px;">🔐</div>
            <h3 style="color:#334155;">Yetkileri Yönetin</h3>
            <p style="color:#64748b;">Değişiklikleri yapıp "Tümünü Kaydet" butonu ile onaylayın.</p>
        </div>

    </main>
</div>

<style>
    .role-nav-item:hover { background: #f8fafc; transform: translateX(5px); }
    .role-nav-item.active { background: #eff6ff; border: 1px solid #dbeafe; }
    .role-nav-item.active strong { color: #2563eb; }

    .perm-card:focus-within { border-color: #3b82f6; box-shadow: 0 10px 20px rgba(0,0,0,0.05); }

    /* Toggle Switch Style */
    .toggle-switch { position: relative; width: 44px; height: 22px; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-switch label { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #cbd5e1; transition: .4s; border-radius: 34px; }
    .toggle-switch label:before { position: absolute; content: ""; height: 16px; width: 16px; left: 3px; bottom: 3px; background-color: white; transition: .4s; border-radius: 50%; }
    .toggle-switch input:checked + label { background-color: #10b981; }
    .toggle-switch input:checked + label:before { transform: translateX(22px); }

    .disabled-toggle label { background-color: #e2e8f0 !important; cursor: not-allowed !important; }
    .disabled-toggle label:before { background-color: #f1f5f9 !important; }

    @@keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>

<script>
    function selectRole(id) {
        document.getElementById('role-empty-state').style.display = 'none';
        document.querySelectorAll('.role-content-pane').forEach(el => el.style.display = 'none');
        document.querySelectorAll('.role-nav-item').forEach(el => el.classList.remove('active'));
        
        const pane = document.getElementById('content-' + id);
        if (pane) pane.style.display = 'block';
        
        const nav = document.getElementById('nav-' + id);
        if (nav) nav.classList.add('active');
    }

    window.onload = function() {
        selectRole('Admin');
    }
</script>
