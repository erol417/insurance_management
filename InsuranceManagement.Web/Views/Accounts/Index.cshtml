@model InsuranceManagement.Web.ViewModels.AccountsIndexViewModel
@{
    var employees = ViewBag.Employees as List<InsuranceManagement.Web.Domain.Employee> ?? [];
    var canManageAll = User.IsInRole("Admin") || User.IsInRole("Manager") || User.IsInRole("SalesManager") || User.IsInRole("Operations");
    var prevPage = Math.Max(1, Model.CurrentPage - 1);
    var nextPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
    ViewData["Title"] = "Musteriler";
    ViewData["Subtitle"] = "Musteri ve firma kayitlari";
}

<div class="premium-strip">
    <div>
        <strong>Musteri Yonetim Merkezi</strong>
        <span>Bireysel ve kurumsal hesaplari tek tablo uzerinden guncelle, sahiplik ve veri kalitesini izleyin.</span>
    </div>
    <div class="inline-actions">
        <a class="btn primary" asp-action="Create">Detayli Form</a>
    </div>
</div>

<div class="panel filters-bar">
    <form method="get" class="filters-inline">
        <div class="filter-group">
            <i data-lucide="search"></i>
            <input type="text" name="searchTerm" placeholder="Musteri Adi, Kod veya Telefon..." value="@ViewBag.SearchTerm" />
        </div>
        
        <select name="status" class="filter-select">
            <option value="">-- Durum --</option>
            <option value="Active" selected="@(ViewBag.Status == "Active")">Aktif</option>
            <option value="Passive" selected="@(ViewBag.Status == "Passive")">Pasif</option>
        </select>

        <div class="filter-actions">
            <button type="submit" class="btn primary btn-icon-only" title="Filtrele">
                <i data-lucide="filter"></i>
            </button>
            <a asp-action="Index" class="btn ghost btn-icon-only" title="Temizle">
                <i data-lucide="rotate-ccw"></i>
            </a>
        </div>
    </form>
</div>

<div class="page-actions" style="margin-bottom:14px;">
    <button type="button" class="btn" onclick="toggleAccountInsertRow()">Yeni Satir Ekle</button>
    <button type="button" class="btn secondary" id="save-all-accounts-btn">Degisiklikleri Kaydet</button>
    <button type="button" class="btn ghost" id="clear-account-draft-btn">Taslagi Temizle</button>
</div>

<div class="panel">
    <div class="note-box">
        <strong>Grid duzenleme</strong>
        <p>Bu ekranda musteri ve firma kayitlari tablo uzerinden hizli duzenlenir. Tum degisiklikler taslakta tutulur ve tek kaydetme ile islenir.</p>
        <p>Sorumlu personel, durum ve temel iletisim alanlari ayni akis icinde duzenlenir; operasyon ekibi icin hizli bakim ekranidir.</p>
    </div>
    <div class="table-scroll">
        <table class="data-table compact-table">
            <thead>
                <tr>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "code" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="code" 
                           asp-route-isDescending="@(ViewBag.SortBy == "code" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Kod @if(ViewBag.SortBy == "code") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "type" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="type" 
                           asp-route-isDescending="@(ViewBag.SortBy == "type" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Tip @if(ViewBag.SortBy == "type") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "displayname" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="displayname" 
                           asp-route-isDescending="@(ViewBag.SortBy == "displayname" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Ad / Unvan @if(ViewBag.SortBy == "displayname") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "city" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="city" 
                           asp-route-isDescending="@(ViewBag.SortBy == "city" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Sehir @if(ViewBag.SortBy == "city") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Ilce</th>
                    <th>Telefon</th>
                    <th>E-posta</th>
                    <th>Vergi No</th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "employee" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="employee" 
                           asp-route-isDescending="@(ViewBag.SortBy == "employee" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Personel @if(ViewBag.SortBy == "employee") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>
                        <a class="sortable-link @(ViewBag.SortBy == "status" ? "active" : "")" 
                           asp-action="Index" 
                           asp-route-sortBy="status" 
                           asp-route-isDescending="@(ViewBag.SortBy == "status" ? (!ViewBag.IsDescending).ToString().ToLower() : "false")"
                           asp-route-searchTerm="@ViewBag.SearchTerm"
                           asp-route-status="@ViewBag.Status">
                            Durum @if(ViewBag.SortBy == "status") { <i data-lucide="@(ViewBag.IsDescending ? "chevron-down" : "chevron-up")"></i> }
                        </a>
                    </th>
                    <th>Not</th>
                </tr>
            </thead>
            <tbody>
                <tr id="account-insert-row" class="inline-entry-row" style="display:none;">
                    <td><span class="muted">Yeni</span></td>
                    <td>
                        <select data-field="accountType" class="cell-input cell-select">
                            <option value="Corporate">Kurumsal</option>
                            <option value="Individual">Bireysel</option>
                        </select>
                    </td>
                    <td><input data-field="displayName" class="cell-input" placeholder="Ad veya unvan" /></td>
                    <td><input data-field="city" class="cell-input" placeholder="Sehir" /></td>
                    <td><input data-field="district" class="cell-input" placeholder="Ilce" /></td>
                    <td><input data-field="phone" class="cell-input" placeholder="Telefon" /></td>
                    <td><input data-field="email" class="cell-input" placeholder="E-posta" /></td>
                    <td><input data-field="taxNumber" class="cell-input" placeholder="Vergi no" /></td>
                    <td>
                        @if (canManageAll)
                        {
                            <select data-field="ownerEmployeeId" class="cell-input cell-select">
                                <option value="">-</option>
                                @foreach (var employee in employees)
                                {
                                    <option value="@employee.Id">@employee.FullName</option>
                                }
                            </select>
                        }
                        else
                        {
                            <input type="hidden" data-field="ownerEmployeeId" value="@Model.NewAccount.OwnerEmployeeId" />
                            <span class="pill">@employees.FirstOrDefault()?.FullName</span>
                        }
                    </td>
                    <td><input data-field="status" class="cell-input" value="Aktif" /></td>
                    <td><input data-field="notes" class="cell-input" placeholder="Not" /></td>
                </tr>
                @foreach (var account in Model.Items)
                {
                    <tr data-account-id="@account.Id">
                        <td><a asp-action="Details" asp-route-id="@account.Id">@account.Code</a></td>
                        <td>
                            <select data-field="accountType" class="cell-input cell-select">
                                @foreach (InsuranceManagement.Web.Domain.AccountType type in Enum.GetValues(typeof(InsuranceManagement.Web.Domain.AccountType)))
                                {
                                    @if (account.AccountType == type)
                                    {
                                        <option value="@type" selected>@type.ToDisplayText()</option>
                                    }
                                    else
                                    {
                                        <option value="@type">@type.ToDisplayText()</option>
                                    }
                                }
                            </select>
                        </td>
                        <td><input data-field="displayName" class="cell-input" value="@account.DisplayName" /></td>
                        <td><input data-field="city" class="cell-input" value="@account.City" /></td>
                        <td><input data-field="district" class="cell-input" value="@account.District" /></td>
                        <td><input data-field="phone" class="cell-input" value="@account.Phone" /></td>
                        <td><input data-field="email" class="cell-input" value="@account.Email" /></td>
                        <td><input data-field="taxNumber" class="cell-input" value="@account.TaxNumber" /></td>
                        <td>
                            @if (canManageAll)
                            {
                                <select data-field="ownerEmployeeId" class="cell-input cell-select">
                                    <option value="">-</option>
                                    @foreach (var employee in employees)
                                    {
                                        @if (account.OwnerEmployeeId == employee.Id)
                                        {
                                            <option value="@employee.Id" selected>@employee.FullName</option>
                                        }
                                        else
                                        {
                                            <option value="@employee.Id">@employee.FullName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="hidden" data-field="ownerEmployeeId" value="@account.OwnerEmployeeId" />
                                <span class="pill">@employees.FirstOrDefault(x => x.Id == account.OwnerEmployeeId)?.FullName</span>
                            }
                        </td>
                        <td><input data-field="status" class="cell-input" value="@account.Status" /></td>
                        <td><input data-field="notes" class="cell-input" value="@account.Notes" /></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="page-actions split-actions" style="margin-top:16px;">
        <div class="pager">
            <a class="btn ghost grid-page-link @(Model.CurrentPage == 1 ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@prevPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-status="@ViewBag.Status"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Onceki</a>
            
            <span class="pill">Sayfa @Model.CurrentPage / @Model.TotalPages</span>
            
            <a class="btn ghost grid-page-link @(Model.CurrentPage == Model.TotalPages ? "disabled-link" : "")" 
               asp-action="Index" 
               asp-route-page="@nextPage" 
               asp-route-pageSize="@Model.PageSize"
               asp-route-searchTerm="@ViewBag.SearchTerm"
               asp-route-status="@ViewBag.Status"
               asp-route-sortBy="@ViewBag.SortBy"
               asp-route-isDescending="@ViewBag.IsDescending">Sonraki</a>
        </div>
        <div class="muted">Toplam @Model.TotalCount kayit</div>
    </div>
</div>

@await Html.PartialAsync("_GridBulkSaveForm", new InsuranceManagement.Web.ViewModels.GridBulkSaveFormViewModel
{
    ActionName = "BulkSave",
    FormId = "account-bulk-save-form",
    PayloadInputId = "account-bulk-payload",
    Page = Model.CurrentPage
})

@section Scripts {
    <script>
        function toggleAccountInsertRow() {
            InsuranceGridDraft.toggleRow("account-insert-row");
        }

        InsuranceGridDraft.create({
            storageKey: "account-grid-draft-v1",
            rowSelector: "tr[data-account-id]",
            rowIdAttribute: "data-account-id",
            insertRowId: "account-insert-row",
            saveButtonId: "save-all-accounts-btn",
            clearButtonId: "clear-account-draft-btn",
            formId: "account-bulk-save-form",
            payloadInputId: "account-bulk-payload",
            clearOnLoad: @(((TempData["ClearGridDraftKey"] as string) == "account-grid-draft-v1").ToString().ToLowerInvariant())
        });
    </script>
}
