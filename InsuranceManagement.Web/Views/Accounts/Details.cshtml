@model InsuranceManagement.Web.Domain.Account
@{
    var owner = ViewBag.Owner as InsuranceManagement.Web.Domain.Employee;
    var activities = ViewBag.Activities as List<InsuranceManagement.Web.Domain.Activity> ?? [];
    var sales = ViewBag.Sales as List<InsuranceManagement.Web.Domain.Sale> ?? [];
    ViewData["Title"] = "Musteri Detayi";
    ViewData["Subtitle"] = "Hesap gecmisi ve bagli kayitlar";
}
<div class="grid equal-2">
    <div class="panel">
        <div class="list">
            <div class="list-item"><strong>Kod</strong><span>@Model.Code</span></div>
            <div class="list-item"><strong>Ad</strong><span>@Model.DisplayName</span></div>
            <div class="list-item"><strong>Tip</strong><span>@Model.AccountType.ToDisplayText()</span></div>
            <div class="list-item"><strong>Sorumlu</strong><span>@(owner?.FullName ?? "-")</span></div>
            <div class="list-item"><strong>Sehir</strong><span>@Model.City / @Model.District</span></div>
        </div>
        <div class="note-box"><strong>Not</strong><p>@Model.Notes</p></div>
    </div>
    <div class="panel">
        <div class="section-title"><h3>Bagli satislar</h3><span class="pill">@sales.Count kayit</span></div>
        <div class="list">
            @foreach (var sale in sales)
            {
                <div class="list-item"><strong>@sale.Code</strong><span>@sale.ProductType</span></div>
            }
        </div>
    </div>
</div>
<div class="panel" style="margin-top:18px;">
    <div class="section-title"><h3>Aktivite gecmisi</h3><span class="pill">@activities.Count kayit</span></div>
    <table class="table">
        <thead><tr><th>Aktivite</th><th>Tarih</th><th>Temas</th><th>Sonuc</th></tr></thead>
        <tbody>
        @foreach (var activity in activities)
        {
            <tr><td>@activity.Code</td><td>@activity.ActivityDate.ToString("dd.MM.yyyy")</td><td>@activity.ContactStatus</td><td>@activity.OutcomeStatus</td></tr>
        }
        </tbody>
    </table>
</div>
<div class="page-actions">
    <a class="btn" asp-action="Edit" asp-route-id="@Model.Id">Duzenle</a>
    <form asp-action="Delete" method="post" class="inline-form">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn secondary">Sil</button>
    </form>
</div>
